# Local runtime profile
APP_ENV=local
SERVER_PORT=8080
HTTP_TIMEOUT_SECONDS=30

# Provider mode
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
RERANKER_PROVIDER=mock
VECTOR_PROVIDER=inmemory

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_API_KEY=
LLM_MODEL=meta-llama/llama-4-scout
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=30
EMBEDDING_API_KEY=
EMBEDDING_MODEL=baai/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MAX_CHARS=4000
EMBEDDING_BATCH_SIZE=32

# Cohere reranker
RERANKER_BASE_URL=https://api.cohere.com
RERANKER_API_KEY=
RERANKER_MODEL=rerank-v3.5
RERANKER_TOP_K=5

# Vector index
VECTOR_COLLECTION=law_articles
VECTOR_TOP_K=5
QDRANT_PORT=6333
QDRANT_BASE_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_DISTANCE=Cosine

# PostgreSQL profile
POSTGRES_PORT=5432
POSTGRES_DB=law_research
POSTGRES_USER=law_research
POSTGRES_PASSWORD=change_me
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/law_research
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=law_research
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Law source
LAW_SOURCE_REPO_URL=https://github.com/legalize-kr/legalize-kr.git
LAW_SOURCE_DIR=C:/dev/legalize-kr
LAW_SOURCE_BRANCH=main
LAW_SOURCE_INCLUDE_DIRS=\uB300\uC678\uBB34\uC5ED\uBC95,\uBC29\uC704\uC0AC\uC5C5\uBC95,\uAD00\uC138\uBC95,\uC678\uAD6D\uD658\uAC70\uB798\uBC95,\uAD6D\uAC00\uCCA8\uB2E8\uC804\uB7B5\uC0B0\uC5C5\uACBD\uC7C1\uB825\uAC15\uD654\uBC0F\uBCF4\uD638\uC5D0\uAD00\uD55C\uD2B9\uBCC4\uC870\uCE58\uBC95,\uC0B0\uC5C5\uAE30\uC220\uC758\uC720\uCD9C\uBC29\uC9C0\uBC0F\uBCF4\uD638\uC5D0\uAD00\uD55C\uBC95\uB960,\uAD6D\uBC29\uACFC\uD559\uAE30\uC220\uD601\uC2E0\uCD09\uC9C4\uBC95,\uAD70\uC218\uD488\uAD00\uB9AC\uBC95
LAW_SOURCE_INCLUDE_FILES=\uBC95\uB960.md,\uC2DC\uD589\uB839.md,\uC2DC\uD589\uADDC\uCE59.md

# RAG/search
RAG_TOP_K=5
RAG_SNAPSHOT_PREFIX=law
SEARCH_LOG_RETENTION_DAYS=90

# Safety/logging
LOG_SENSITIVE_DATA=false
STORE_RAW_QUESTION=false
ENABLE_AGENT_TRACE=true
ADMIN_REINDEX_ENABLED=false

# Local H2 console
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console
REFERENCE_DATA_ENABLED=false
